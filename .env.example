# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poaley_chedec
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poaley_chedec_test

# Backend
SECRET_KEY=change-me-to-a-long-random-secret-key
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TIMEZONE=Asia/Jerusalem

# Zmanim (Hebcal location for computed prayer times — אפרים 52, אשקלון)
ZMANIM_LATITUDE=31.669
ZMANIM_LONGITUDE=34.571
ZMANIM_TZID=Asia/Jerusalem

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Admin seed (JSON array)
ADMIN_USERS=[{"username":"admin","password":"changeme123"}]

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@poaleitzedek.org
CONTACT_RECIPIENT_EMAIL=taktuk01@gmail.com

# Cloudinary (required for admin image uploads — get from https://console.cloudinary.com)
# CLOUDINARY_CLOUD_NAME is a short name like "my-app", not a UUID
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
